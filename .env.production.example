# =============================================================================
# Kesher — Production environment template
# =============================================================================
# Copy this file to your hosting provider's environment-variables panel.
# Vercel: Project Settings → Environment Variables (Production scope only).
# Never commit a filled-in version of this file.
# =============================================================================

# ── Runtime ───────────────────────────────────────────────────────────────
NODE_ENV="production"
AI_ROUTE_AUTH_MODE="production"
PORT="3000"

# ── Gemini API (server-only — never expose to client) ─────────────────────
GEMINI_API_KEY=""

# ── Firebase (server-side admin) ──────────────────────────────────────────
FIREBASE_PROJECT_ID="gen-lang-client-0904321862"
FIREBASE_CLIENT_EMAIL=""
FIREBASE_PRIVATE_KEY=""
FIREBASE_APP_CHECK_ENABLED="true"

# ── Firebase (client) — also set as VITE_* in Vercel for the build ────────
VITE_RECAPTCHA_ENTERPRISE_KEY=""
VITE_PROTOTYPE_DEMO_MODE="false"

# ── Database (Neon Postgres optional) ─────────────────────────────────────
DATABASE_MODE="firestore"
# Or "neon" — then provide:
# DATABASE_URL=""
# DIRECT_DATABASE_URL=""
# NEON_PROJECT_ID=""

# ── Rate limiting backend (Firestore for multi-instance) ──────────────────
RATE_LIMIT_BACKEND="firestore"
# Or "memory" for single-instance dev / preview

# ── Observability ────────────────────────────────────────────────────────
VITE_SENTRY_DSN=""
SENTRY_DSN=""

# ── Canonical URL (for the prototype-mode redirect logic) ─────────────────
APP_URL="https://google-ai-studio-sage-sigma.vercel.app"
VITE_STABLE_PROTOTYPE_URL="https://google-ai-studio-sage-sigma.vercel.app"

# ── Build metadata (auto-populated by Vercel — do not set manually) ───────
# VITE_VERCEL_ENV
# VITE_VERCEL_GIT_COMMIT_SHA
# VITE_VERCEL_GIT_COMMIT_REF
# VITE_VERCEL_URL
