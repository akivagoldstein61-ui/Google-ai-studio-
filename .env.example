# Public runtime mode only (non-sensitive)
VITE_DATABASE_MODE="mock"

# Server-only database lifecycle configuration (never expose client-side)
DATABASE_MODE="mock"
DATABASE_URL="postgres://<user>:<password>@<host>:5432/<database>"
DIRECT_DATABASE_URL="postgres://<user>:<password>@<host>:5432/<database>"
NEON_PROJECT_ID="neon-project-id"
NEON_BRANCH_ID="neon-branch-id"

# Gemini API key (server-side only)
GEMINI_API_KEY=""

# Firebase server credentials
FIREBASE_PROJECT_ID=""
FIREBASE_CLIENT_EMAIL=""
FIREBASE_PRIVATE_KEY=""
FIREBASE_APP_CHECK_ENABLED="false"

# App runtime URL (server-side)
APP_URL="https://example.com"

# Auth mode
AI_ROUTE_AUTH_MODE="prototype"
