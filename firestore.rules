rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "akivagoldstein61@gmail.com" && request.auth.token.email_verified == true));
    }
    function isMatchParticipant(matchId) {
      return isAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/matches/$(matchId)).data.users;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{uid} {
      allow read: if isAuthenticated();
      allow create, update: if isOwner(uid) || isAdmin();
      allow delete: if isAdmin();
      
      match /private/{docId} {
        allow read, write: if isOwner(uid) || isAdmin();
      }
    }

    match /likes/{likeId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.fromId || request.auth.uid == resource.data.toId || isAdmin());
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.fromId;
      allow delete: if isAuthenticated() && (request.auth.uid == resource.data.fromId || isAdmin());
    }

    match /passes/{passId} {
      // Private to the user who passed — never readable by the target
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.fromId || isAdmin());
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.fromId;
      allow delete: if isAuthenticated() && (request.auth.uid == resource.data.fromId || isAdmin());
    }

    match /notifications/{notifId} {
      // Each notification has a userId; only that user can read.
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin());
      allow create, update, delete: if isAdmin();
    }

    match /conversations/{conversationId} {
      allow read: if isAuthenticated() && (request.auth.uid in resource.data.participants || isAdmin());
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (request.auth.uid in resource.data.participants || isAdmin());
      allow delete: if isAdmin();

      // Real-time messages subcollection
      match /messages/{messageId} {
        function isConversationParticipant() {
          return isAuthenticated() &&
            request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants;
        }
        allow read: if isConversationParticipant() || isAdmin();
        allow create: if isConversationParticipant() &&
          request.auth.uid == request.resource.data.senderId &&
          request.resource.data.text is string &&
          request.resource.data.text.size() > 0 &&
          request.resource.data.text.size() <= 2000;
        // Messages are immutable once written (no edit; report and re-send pattern)
        allow update, delete: if isAdmin();
      }
    }
    match /matches/{matchId} {
      allow read: if isAuthenticated() && (request.auth.uid in resource.data.users || isAdmin());
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (request.auth.uid in resource.data.users || isAdmin());
      allow delete: if isAdmin();

      match /messages/{messageId} {
        allow read, create: if isMatchParticipant(matchId) || isAdmin();
        allow update, delete: if isAdmin();
      }
    }
    match /reports/{reportId} {
      allow create: if isAuthenticated();
      allow read, update, delete: if isAdmin();
    }

    match /blocks/{blockId} {
      allow create: if isAuthenticated();
      allow read, update, delete: if isAdmin();
    }

    match /unmatches/{unmatchId} {
      allow create: if isAuthenticated();
      allow read, update, delete: if isAdmin();
    }

    match /support_requests/{requestId} {
      allow create: if isAuthenticated();
      allow read, update, delete: if isAdmin();
    }

    match /delete_requests/{requestId} {
      allow create: if isAuthenticated();
      allow read, update, delete: if isAdmin();
    }

    // Cached compatibility reflection cards. Linked to a /consents record;
    // the server invalidates these when consent is revoked.
    match /compatibilityCards/{cardId} {
      allow read: if isAuthenticated() && (
        request.auth.uid in resource.data.users || isAdmin()
      );
      // Cards are server-issued only; clients cannot create/update.
      allow create, update, delete: if isAdmin();
    }

    // Mutual consent records (Gate 5 — compatibility reflection prerequisite).
    // Only the two users in the consent pair may read/write their own record.
    match /consents/{consentId} {
      allow read: if isAuthenticated() && (
        request.auth.uid in resource.data.users || isAdmin()
      );
      allow create: if isAuthenticated() &&
        request.auth.uid in request.resource.data.users &&
        request.resource.data.users.size() == 2;
      allow update: if isAuthenticated() &&
        request.auth.uid in resource.data.users;
      allow delete: if isAdmin();
    }

    // Permissioned share cards: owner manages; recipient may read while not expired/revoked.
    match /shareCards/{cardId} {
      allow read: if isAuthenticated() && (
        request.auth.uid == resource.data.ownerUid ||
        (
          request.auth.uid == resource.data.recipientUid &&
          resource.data.revokedAt == null &&
          resource.data.expiresAt > request.time
        ) ||
        isAdmin()
      );
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.ownerUid;
      allow update: if isAuthenticated() && (
        request.auth.uid == resource.data.ownerUid || isAdmin()
      );
      allow delete: if isAdmin();

      match /auditLog/{eventId} {
        allow read: if isAuthenticated() && (
          request.auth.uid == get(/databases/$(database)/documents/shareCards/$(cardId)).data.ownerUid ||
          isAdmin()
        );
        allow write: if isAdmin();
      }
    }
  }
}
